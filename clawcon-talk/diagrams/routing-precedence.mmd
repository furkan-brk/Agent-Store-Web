flowchart TD
    M["📨 Inbound message<br/>(channel, accountId, peer, guildId, teamId, roles)"]
    A1["✅ agentId resolved"]
    D["⚙️ default agent"]

    M --> P{"1. peer match?<br/><i>exact DM/group/channel ID</i>"}
    P -- yes --> A1
    P -- no --> PP{"2. parent peer?<br/><i>thread inheritance</i>"}
    PP -- yes --> A1
    PP -- no --> GR{"3. guild + roles?<br/><i>Discord guild AND role set</i>"}
    GR -- yes --> A1
    GR -- no --> G{"4. guild?<br/><i>Discord guild only</i>"}
    G -- yes --> A1
    G -- no --> T{"5. teamId?<br/><i>Slack team</i>"}
    T -- yes --> A1
    T -- no --> AC{"6. accountId?<br/><i>explicit, non-wildcard</i>"}
    AC -- yes --> A1
    AC -- no --> CH{"7. channel-level?<br/><i>wildcard accountId</i>"}
    CH -- yes --> A1
    CH -- no --> D

    style M fill:#1e3a5f,stroke:#4a90e2,color:#fff
    style A1 fill:#2d5016,stroke:#7cb342,color:#fff
    style D fill:#5d4037,stroke:#bf8970,color:#fff
