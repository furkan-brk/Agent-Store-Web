%% Multi-Agent Isolation: 5 dimensions per agent
%% Render: mmdc -i isolation-tree.mmd -o isolation-tree.svg

flowchart LR
    subgraph Gateway["🌐 Single OpenClaw Gateway"]
        subgraph main["agent: main"]
            m1["📁 workspace/"]
            m2["🔐 auth-profiles.json"]
            m3["💾 sessions/"]
            m4["🛠 tools (default)"]
            m5["📦 sandbox: off"]
        end

        subgraph family["agent: family"]
            f1["📁 workspace-family/"]
            f2["🔐 auth-profiles.json<br/><i>independent</i>"]
            f3["💾 sessions/"]
            f4["🛠 tools.allow=read"]
            f5["📦 sandbox: docker"]
        end

        subgraph coding["agent: coding"]
            c1["📁 workspace-coding/"]
            c2["🔐 auth-profiles.json<br/><i>independent</i>"]
            c3["💾 sessions/"]
            c4["🛠 tools.allow=*"]
            c5["📦 sandbox: docker"]
        end
    end

    style main fill:#1e3a5f,stroke:#4a90e2,color:#fff
    style family fill:#5d4037,stroke:#bf8970,color:#fff
    style coding fill:#2d5016,stroke:#7cb342,color:#fff
