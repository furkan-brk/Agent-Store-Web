%% Agent Store ON TOP OF OpenClaw - layered stack architecture
%% Slayt 11 - main architecture anchor
%% Render: mmdc -i agent-store-vs-openclaw.mmd -o agent-store-vs-openclaw.svg -t dark -b transparent
%% NOTE: file kept under old name for git history; content now reflects "with OpenClaw" stack architecture

flowchart TB
    USER["👤 User<br/><i>browser</i>"]

    subgraph AS["🎮 Agent Store — product layer"]
        direction TB
        FE["Flutter Web<br/>(Vercel)"]
        GW["API Gateway :8080 (Go)"]
        AUTH["authsvc<br/>wallet auth"]
        AGENT["agentsvc<br/>CRUD + library"]
        AI["aipipelinesvc<br/>analyze + score"]
        GUILD["guildsvc<br/><b>Guild Master</b>"]
        WS["workspacesvc<br/><b>Legend DAG</b>"]

        FE --> GW
        GW --> AUTH
        GW --> AGENT
        GW --> AI
        GW --> GUILD
        GW --> WS
    end

    subgraph BRIDGE["🌉 Bridge plugin (v2 milestone)"]
        direction LR
        DISPATCH["Team → bindings<br/>dispatch"]
        EXPORT["openclaw.json<br/>exporter"]
    end

    subgraph OC["⚙️ OpenClaw — multi-agent runtime"]
        direction TB
        ROUTING["routing precedence<br/><i>8 tiers</i>"]
        ISOLATION["per-agent isolation<br/><i>5 dimensions</i>"]
        SPAWN["sessions_spawn<br/>chains"]
        AUTHPROF["auth-profiles<br/>per agent"]
    end

    subgraph DATA["🔗 Data + chain"]
        PG["PostgreSQL"]
        REDIS["Redis"]
        MONAD["Monad on-chain<br/><i>credits + registry</i>"]
    end

    USER --> FE
    AS --> BRIDGE
    BRIDGE --> OC
    AGENT --> PG
    AGENT --> REDIS
    AUTH --> MONAD
    GUILD --> AI

    style AS fill:#1a1320,stroke:#f59e0b,color:#fff
    style BRIDGE fill:#0f2419,stroke:#10b981,color:#fff
    style OC fill:#1e1e2e,stroke:#7c3aed,color:#fff
    style DATA fill:#161b22,stroke:#7d8590,color:#fff
    style USER fill:#0d1117,stroke:#7d8590,color:#fff
