# =========================================================
# Agent Store — Production Environment Variables
# Copy to Railway → Variables and fill in actual values.
# =========================================================

# --- Server ---
PORT=8080

# --- PostgreSQL (Railway Postgres plugin fills these automatically) ---
POSTGRES_HOST=
POSTGRES_PORT=5432
POSTGRES_USER=
POSTGRES_PASSWORD=
POSTGRES_DB=agent_store

# --- Auth ---
# Generate with: openssl rand -hex 32
JWT_SECRET=

# --- Claude AI ---
CLAUDE_API_KEY=sk-ant-

# --- CORS ---
# Comma-separated list of allowed frontend origins
ALLOWED_ORIGINS=https://<your-app>.vercel.app

# --- Blockchain ---
MONAD_RPC_URL=https://testnet-rpc.monad.xyz
CREDITS_CONTRACT_ADDRESS=

# =========================================================
# GitHub Actions Secrets required for CI/CD:
#   RAILWAY_TOKEN         — Railway API token
#   VERCEL_TOKEN          — Vercel API token
#   VERCEL_ORG_ID         — Vercel org/team ID
#   VERCEL_PROJECT_ID     — Vercel project ID
# GitHub Actions Variables:
#   API_BASE_URL          — e.g. https://<app>.up.railway.app
# =========================================================
